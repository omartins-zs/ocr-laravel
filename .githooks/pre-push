#!/bin/sh

echo "---------------------------------------"
echo "Iniciando hooks de pre-push..."
echo "---------------------------------------"

echo "[1/3] Rodando bateria de testes..."
php artisan test
TEST_STATUS=$?

if [ $TEST_STATUS -ne 0 ]; then
    echo "[ERRO] Falha nos testes da aplicacao."
    echo "Push abortado."
    exit 1
fi

echo "Testes OK."

echo "[2/3] Rodando Laravel Pint..."
./vendor/bin/pint --test
PINT_STATUS=$?

if [ $PINT_STATUS -ne 0 ]; then
    echo "[ERRO] Laravel Pint encontrou problemas de formatacao."
    echo "Push abortado."
    exit 1
fi

echo "Pint OK."

echo "[3/3] Rodando Larastan..."
./vendor/bin/phpstan analyse --memory-limit=1G
STAN_STATUS=$?

if [ $STAN_STATUS -ne 0 ]; then
    echo "[ERRO] Larastan encontrou falhas no codigo PHP."
    echo "Push abortado."
    exit 1
fi

echo "Larastan OK."
echo "Push liberado."

exit 0
