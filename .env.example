APP_NAME="OCR Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# APP URL
# Local
# APP_URL=http://127.0.0.1:8080
# Docker (ativo)
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Sao_Paulo

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# LOG
# Local
# LOG_CHANNEL=stack
# LOG_STACK=single
# LOG_DEPRECATIONS_CHANNEL=null
# LOG_LEVEL=debug
# Docker (ativo)
LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# DATABASE
# Local sqlite (rapido)
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite
# Local mysql
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=ocr_platform_local
# DB_USERNAME=root
# DB_PASSWORD=
# Docker postgres (ativo)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ocr_platform
DB_USERNAME=ocr_user
DB_PASSWORD=ocr_pass

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# QUEUE / CACHE
# Local
# QUEUE_CONNECTION=database
# CACHE_STORE=file
# Docker (ativo)
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# REDIS
# Local
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# Docker (ativo)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE=ocr

# OCR SERVICE
OCR_SERVICE_ENABLED=true
# Local
# OCR_SERVICE_URL=http://127.0.0.1:8001
# Docker (ativo - fallback comum no WSL2)
OCR_SERVICE_URL=http://172.17.0.1:8001
# Opcional (alguns ambientes Docker Desktop)
# OCR_SERVICE_URL=http://host.docker.internal:8001

OCR_STORAGE_DISK=local
OCR_HTTP_TIMEOUT=360
OCR_CONNECT_TIMEOUT=10
OCR_HTTP_RETRIES=2
OCR_HTTP_RETRY_SLEEP_MS=500
OCR_LANGUAGE=por
OCR_ENABLE_PADDLE=false
OCR_LOG_CHANNEL=ocr_pipeline
OCR_LOG_STACK=stderr,ocr_pipeline_file
OCR_LOG_LEVEL=debug
OCR_LOG_FILE=storage/logs/ocr_pipeline.log
OCR_HEALTH_PATH=/health
OCR_HEALTH_TIMEOUT=3
OCR_HEALTH_CONNECT_TIMEOUT=2
OCR_HEALTH_CACHE_SECONDS=15
OCR_STATUS_POLL_MS=10000
OCR_STATUS_REQUEST_TIMEOUT_MS=5000

# MAIL
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

MEMCACHED_HOST=127.0.0.1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Runtime fallback
APP_RUNTIME_FALLBACKS=false
QUEUE_FALLBACK_CONNECTION=database
CACHE_FALLBACK_STORE=file
SESSION_FALLBACK_DRIVER=database

VITE_APP_NAME="${APP_NAME}"
